<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.LoginController"
            style="-fx-background-color: #1a1a1a;">

    <center>
        <HBox spacing="0" alignment="CENTER" style="-fx-background-color: #1a1a1a;">

            <!-- Left Sidebar - Decorative -->
            <VBox prefWidth="300" style="-fx-background-color: linear-gradient(to bottom, #2d2d2d, #1a1a1a); -fx-padding: 40;" alignment="CENTER" spacing="30" HBox.hgrow="SOMETIMES">
                <VBox alignment="CENTER" spacing="15" VBox.vgrow="ALWAYS">
                    <Label text="AUCTION HOUSE" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #d4af6a;" alignment="CENTER" wrapText="true"/>
                    <Label text="Premium Auctions" style="-fx-font-size: 14; -fx-text-fill: #a8a8a8;" alignment="CENTER" wrapText="true"/>
                    <Separator style="-fx-padding: 10 0 10 0; -fx-border-color: #d4af6a; -fx-border-width: 0.5; -fx-padding: 20 0 20 0;"/>
                    <Label text="Access the world's finest auction collection" style="-fx-font-size: 12; -fx-text-fill: #888888; -fx-line-spacing: 2;" alignment="CENTER" wrapText="true"/>
                </VBox>
                <VBox alignment="BOTTOM_CENTER" spacing="20" VBox.vgrow="ALWAYS">
                    <Separator style="-fx-border-color: #d4af6a; -fx-border-width: 0.5;"/>
                    <Label text="Established 2026" style="-fx-font-size: 11; -fx-text-fill: #666666;" alignment="CENTER"/>
                </VBox>
            </VBox>

            <!-- Right Form Panel -->
            <VBox spacing="0" style="-fx-background-color: #ffffff;" alignment="TOP_CENTER" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                <ScrollPane fitToWidth="true" style="-fx-background-color: #ffffff; -fx-padding: 0; -fx-border-style: none;">
                    <VBox spacing="0" alignment="CENTER" style="-fx-background-color: #ffffff; -fx-padding: 60;">

                        <VBox spacing="40" maxWidth="400" minWidth="300">

                            <!-- Header -->
                            <VBox spacing="8" alignment="CENTER">
                                <Label text="Sign In" styleClass="login-title-main"/>
                                <Label text="Enter your credentials to continue" styleClass="login-subtitle-main"/>
                            </VBox>

                            <!-- Form Fields -->
                            <VBox spacing="24">
                                <!-- Username -->
                                <VBox spacing="8">
                                    <Label text="Username" styleClass="form-label-login"/>
                                    <TextField fx:id="usernameField" promptText="Enter your username" styleClass="login-input" />
                                </VBox>

                                <!-- Password -->
                                <VBox spacing="8">
                                    <Label text="Password" styleClass="form-label-login"/>
                                    <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="login-input" />
                                </VBox>

                                <HBox alignment="CENTER_RIGHT">
                                    <Hyperlink text="Forgot password?" onAction="#goToForgotPassword" styleClass="login-link"/>
                                </HBox>
                            </VBox>

                            <!-- Buttons -->
                            <VBox spacing="12">
                                <Button text="SIGN IN" onAction="#handleLogin" styleClass="login-btn-primary" prefWidth="Infinity"/>
                                <Button text="Don't have an account? Create one" onAction="#goToRegister" styleClass="login-btn-secondary" prefWidth="Infinity"/>
                            </VBox>

                            <!-- Footer -->
                            <Label text="© 2026 Auction House. All rights reserved."
                                    style="-fx-text-fill: #999999; -fx-font-size: 11; -fx-padding: 20 0 0 0;"
                                    alignment="CENTER"/>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>

</BorderPane>
