<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.RegisterController"
            style="-fx-background-color: #1a1a1a;">

    <center>
        <HBox spacing="0" alignment="CENTER" style="-fx-background-color: #1a1a1a;">

            <!-- Left Sidebar - Decorative -->
            <VBox prefWidth="280" style="-fx-background-color: linear-gradient(to bottom, #2d2d2d, #1a1a1a); -fx-padding: 40;" alignment="CENTER" spacing="30" HBox.hgrow="SOMETIMES">
                <VBox alignment="CENTER" spacing="15" VBox.vgrow="ALWAYS">
                    <Label text="AUCTION HOUSE" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #d4af6a;" alignment="CENTER" wrapText="true"/>
                    <Label text="Premium Auctions" style="-fx-font-size: 14; -fx-text-fill: #a8a8a8;" alignment="CENTER" wrapText="true"/>
                    <Separator style="-fx-border-color: #d4af6a; -fx-border-width: 0.5; -fx-padding: 20 0 20 0;"/>
                    <Label text="Join our exclusive community of collectors" style="-fx-font-size: 12; -fx-text-fill: #888888; -fx-line-spacing: 2;" alignment="CENTER" wrapText="true"/>
                </VBox>
                <VBox alignment="BOTTOM_CENTER" spacing="20" VBox.vgrow="ALWAYS">
                    <Separator style="-fx-border-color: #d4af6a; -fx-border-width: 0.5;"/>
                    <Label text="Established 2026" style="-fx-font-size: 11; -fx-text-fill: #666666;" alignment="CENTER"/>
                </VBox>
            </VBox>

            <!-- Right Form Panel -->
            <VBox spacing="0" style="-fx-background-color: #ffffff;" alignment="TOP_CENTER" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                <ScrollPane fitToWidth="true" fitToHeight="false" style="-fx-background-color: #ffffff; -fx-padding: 0; -fx-border-style: none;">
                    <VBox spacing="0" alignment="TOP_CENTER" style="-fx-background-color: #ffffff;">

                        <VBox spacing="30" maxWidth="420" minWidth="300" style="-fx-padding: 50 40 50 40;">

                            <!-- Header -->
                            <VBox spacing="6" alignment="CENTER">
                                <Label text="Create Account" styleClass="register-title-main"/>
                                <Label text="Join our exclusive auction community" styleClass="register-subtitle-main"/>
                            </VBox>

                            <!-- Form Content -->
                            <VBox spacing="20">

                                <!-- Account Information Section -->
                                <VBox spacing="14">
                                    <Label text="Account Information" styleClass="form-section-title"/>

                                    <!-- Username -->
                                    <VBox spacing="6">
                                        <Label text="Username" styleClass="form-label-register"/>
                                        <TextField fx:id="usernameField" promptText="6-20 characters" styleClass="register-input"/>
                                        <Label fx:id="usernameError" styleClass="error-label"/>
                                    </VBox>

                                    <!-- Email -->
                                    <VBox spacing="6">
                                        <Label text="Email Address" styleClass="form-label-register"/>
                                        <TextField fx:id="emailField" promptText="your@email.com" styleClass="register-input"/>
                                        <Label fx:id="emailError" styleClass="error-label"/>
                                    </VBox>

                                    <!-- Password -->
                                    <VBox spacing="6">
                                        <Label text="Password" styleClass="form-label-register"/>
                                        <PasswordField fx:id="passwordField" promptText="Use uppercase, numbers, and special characters" styleClass="register-input"/>
                                        <Label fx:id="passwordError" styleClass="error-label"/>
                                    </VBox>
                                </VBox>

                                <!-- Security Section -->
                                <VBox spacing="14">
                                    <Label text="Security Questions" styleClass="form-section-title"/>

                                    <!-- Question 1 -->
                                    <VBox spacing="6">
                                        <Label text="Security Question 1" styleClass="form-label-register"/>
                                        <TextField fx:id="q1Field" promptText="e.g., What is your pet's name?" styleClass="register-input"/>
                                        <Label fx:id="q1Error" styleClass="error-label"/>
                                    </VBox>

                                    <!-- Answer 1 -->
                                    <VBox spacing="6">
                                        <Label text="Answer 1" styleClass="form-label-register"/>
                                        <TextField fx:id="a1Field" promptText="Your answer" styleClass="register-input"/>
                                        <Label fx:id="a1Error" styleClass="error-label"/>
                                    </VBox>

                                    <!-- Question 2 -->
                                    <VBox spacing="6">
                                        <Label text="Security Question 2" styleClass="form-label-register"/>
                                        <TextField fx:id="q2Field" promptText="e.g., What is your birth city?" styleClass="register-input"/>
                                        <Label fx:id="q2Error" styleClass="error-label"/>
                                    </VBox>

                                    <!-- Answer 2 -->
                                    <VBox spacing="6">
                                        <Label text="Answer 2" styleClass="form-label-register"/>
                                        <TextField fx:id="a2Field" promptText="Your answer" styleClass="register-input"/>
                                        <Label fx:id="a2Error" styleClass="error-label"/>
                                    </VBox>
                                </VBox>

                                <!-- Role Selection Section -->
                                <VBox spacing="14">
                                    <Label text="Account Type" styleClass="form-section-title"/>
                                    <VBox spacing="6">
                                        <Label text="Select Your Role" styleClass="form-label-register"/>
                                        <ChoiceBox fx:id="roleBox" prefWidth="Infinity" styleClass="register-choice"/>
                                    </VBox>
                                </VBox>

                                <!-- Form Error -->
                                <Label fx:id="formError" styleClass="form-error" wrapText="true"/>
                            </VBox>

                            <!-- Buttons -->
                            <VBox spacing="12">
                                <Button text="CREATE ACCOUNT" onAction="#handleRegister" styleClass="register-btn-primary" prefWidth="Infinity"/>
                                <Button text="Back to Login" onAction="#goBack" styleClass="register-btn-secondary" prefWidth="Infinity"/>
                            </VBox>

                            <!-- Footer -->
                            <Label text="© 2026 Auction House. All rights reserved."
                                    style="-fx-text-fill: #999999; -fx-font-size: 11; -fx-padding: 20 0 0 0;"
                                    alignment="CENTER"/>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>

</BorderPane>
