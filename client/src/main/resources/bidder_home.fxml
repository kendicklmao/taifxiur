<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="client.BidderHomeController">

    <!-- TOP -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-padding: 20; -fx-background-color: linear-gradient(to right, #1a1a1a, #2c2c2c); -fx-spacing: 15;">
            <Label text="🔨 BIDDER DASHBOARD" style="-fx-text-fill: #d4af6a; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" style="-fx-text-fill: #ffffff; -fx-font-size: 14px;"/>
            <Button text="CHANGE PASSWORD" onAction="#handleChangePassword" styleClass="dashboard-btn-primary" prefWidth="170"/>
            <Button text="LOGOUT" onAction="#handleLogout" styleClass="dashboard-btn-logout" prefWidth="100"/>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="20" style="-fx-padding: 25; -fx-background-color: #f8f7f5;">
            <VBox spacing="12" style="-fx-border-color: #e8e6e1; -fx-border-width: 1; -fx-padding: 20; -fx-border-radius: 4; -fx-background-color: #ffffff;">
                <VBox spacing="6">
                    <Label text="Wallet" styleClass="dashboard-section-title"/>
                    <Label text="Deposit requests are approved by admin before funds are added" styleClass="dashboard-section-subtitle"/>
                </VBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label fx:id="walletBalanceLabel" text="Balance: loading..." style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="REQUEST DEPOSIT" onAction="#handleDepositRequest" styleClass="dashboard-btn-primary" prefWidth="170"/>
                </HBox>
            </VBox>

            <VBox spacing="8">
                <Label text="Live Auctions" styleClass="dashboard-section-title"/>
                <Label text="Double-click an auction to place your bid" styleClass="dashboard-section-subtitle"/>
            </VBox>

            <ListView fx:id="auctionList" style="-fx-padding: 10; -fx-border-radius: 4; -fx-border-color: #d0ccc6; -fx-background-color: #ffffff;"/>
        </VBox>
    </center>

</BorderPane>
