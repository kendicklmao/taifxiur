<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="client.ForgotPasswordController"
            style="-fx-background-color: #1a1a1a;">

    <center>
        <HBox spacing="0" alignment="CENTER" style="-fx-background-color: #1a1a1a;">
            <VBox prefWidth="300"
                  alignment="CENTER"
                  spacing="30"
                  style="-fx-background-color: linear-gradient(to bottom, #2d2d2d, #1a1a1a); -fx-padding: 40;">
                <VBox alignment="CENTER" spacing="15" VBox.vgrow="ALWAYS">
                    <Label text="ACCOUNT RECOVERY"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #d4af6a;"
                           wrapText="true"/>
                    <Label text="Recover access using your registered email and security answers"
                           style="-fx-font-size: 13; -fx-text-fill: #a8a8a8;"
                           alignment="CENTER"
                           wrapText="true"/>
                </VBox>
                <VBox alignment="BOTTOM_CENTER" spacing="20" VBox.vgrow="ALWAYS">
                    <Label text="Protection for Auction House accounts"
                           style="-fx-font-size: 11; -fx-text-fill: #666666;"
                           wrapText="true"
                           alignment="CENTER"/>
                </VBox>
            </VBox>

            <VBox alignment="TOP_CENTER" HBox.hgrow="ALWAYS" style="-fx-background-color: #ffffff;">
                <ScrollPane fitToWidth="true" style="-fx-background-color: #ffffff; -fx-padding: 0; -fx-border-style: none;">
                    <VBox alignment="CENTER" spacing="0" style="-fx-background-color: #ffffff; -fx-padding: 60;">
                        <VBox maxWidth="450" minWidth="320" spacing="28">
                            <VBox spacing="8" alignment="CENTER">
                                <Label text="Forgot Password" styleClass="register-title-main"/>
                                <Label text="Verify your account and set a new password" styleClass="register-subtitle-main"/>
                            </VBox>

                            <VBox spacing="16">
                                <VBox spacing="8">
                                    <Label text="Username" styleClass="form-label-register"/>
                                    <TextField fx:id="usernameField" promptText="Enter your username" styleClass="register-input"/>
                                </VBox>
                                <VBox spacing="8">
                                    <Label text="Email" styleClass="form-label-register"/>
                                    <TextField fx:id="emailField" promptText="Enter your registered email" styleClass="register-input"/>
                                </VBox>
                                <Button fx:id="loadQuestionsButton"
                                        text="LOAD SECURITY QUESTIONS"
                                        onAction="#handleLoadQuestions"
                                        prefWidth="Infinity"
                                        styleClass="register-btn-primary"/>
                            </VBox>

                            <VBox fx:id="verificationBox" spacing="16">
                                <Label text="Security Verification" styleClass="form-section-title"/>

                                <VBox spacing="6" styleClass="forgot-question-box">
                                    <Label text="Question 1" styleClass="form-label-register"/>
                                    <Label fx:id="question1Label" wrapText="true" styleClass="forgot-question-text"/>
                                </VBox>
                                <TextField fx:id="answer1Field" promptText="Answer for question 1" styleClass="register-input"/>

                                <VBox spacing="6" styleClass="forgot-question-box">
                                    <Label text="Question 2" styleClass="form-label-register"/>
                                    <Label fx:id="question2Label" wrapText="true" styleClass="forgot-question-text"/>
                                </VBox>
                                <TextField fx:id="answer2Field" promptText="Answer for question 2" styleClass="register-input"/>

                                <VBox spacing="8">
                                    <Label text="New Password" styleClass="form-label-register"/>
                                    <PasswordField fx:id="newPasswordField" promptText="At least 6 chars, upper/lower/number/special" styleClass="register-input"/>
                                </VBox>
                                <VBox spacing="8">
                                    <Label text="Confirm New Password" styleClass="form-label-register"/>
                                    <PasswordField fx:id="confirmPasswordField" promptText="Re-enter your new password" styleClass="register-input"/>
                                </VBox>
                            </VBox>

                            <VBox spacing="12">
                                <Button fx:id="resetPasswordButton"
                                        text="RESET PASSWORD"
                                        onAction="#handleResetPassword"
                                        prefWidth="Infinity"
                                        styleClass="register-btn-primary"/>
                                <Button fx:id="switchAccountButton"
                                        text="USE ANOTHER ACCOUNT"
                                        onAction="#handleUseAnotherAccount"
                                        prefWidth="Infinity"
                                        styleClass="register-btn-secondary"/>
                                <Button text="BACK TO SIGN IN"
                                        onAction="#goBack"
                                        prefWidth="Infinity"
                                        styleClass="register-btn-secondary"/>
                            </VBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>

</BorderPane>
