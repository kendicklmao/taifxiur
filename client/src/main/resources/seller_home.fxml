<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="client.SellerHomeController">

    <!-- TOP -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT"
              style="-fx-padding: 20; -fx-background-color: linear-gradient(to right, #1a1a1a, #2c2c2c); -fx-spacing: 15;">
            <Label text="🏪 SELLER DASHBOARD"
                   style="-fx-text-fill: #d4af6a; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="LOGOUT" onAction="#handleLogout" styleClass="dashboard-btn-logout" prefWidth="100"/>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f8f7f5; -fx-padding: 0; -fx-border-style: none;">
            <VBox spacing="20" style="-fx-padding: 25; -fx-background-color: #f8f7f5;">

                <!-- CREATE AUCTION SECTION -->
                <VBox spacing="12" style="-fx-border-color: #e8e6e1; -fx-border-width: 1; -fx-padding: 20; -fx-border-radius: 4; -fx-background-color: #ffffff;">
                    <VBox spacing="6">
                        <Label text="Create New Auction" styleClass="dashboard-section-title"/>
                        <Label text="List a new item for auction" styleClass="dashboard-section-subtitle"/>
                    </VBox>

                    <VBox spacing="12">
                        <!-- Item Details -->
                        <VBox spacing="8">
                            <Label text="Item Details" styleClass="form-section-title"/>
                            <VBox spacing="6">
                                <Label text="Product Name" styleClass="form-label-register"/>
                                <TextField fx:id="itemNameField" promptText="Enter product name" styleClass="dashboard-input"/>
                            </VBox>
                            <VBox spacing="6">
                                <Label text="Starting Price" styleClass="form-label-register"/>
                                <TextField fx:id="startPriceField" promptText="Enter starting price" styleClass="dashboard-input"/>
                            </VBox>
                            <VBox spacing="6">
                                <Label text="Category" styleClass="form-label-register"/>
                                <ChoiceBox fx:id="categoryBox" style="-fx-padding: 10; -fx-font-size: 13; -fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-background-color: #f9f9f9; -fx-border-radius: 4;"/>
                            </VBox>
                        </VBox>

                        <!-- Dynamic Form -->
                        <VBox fx:id="dynamicForm" spacing="10"/>

                        <!-- Description -->
                        <VBox spacing="6">
                            <Label text="Product Description" styleClass="form-label-register"/>
                            <TextArea fx:id="descField" promptText="Detailed description of your item" style="-fx-padding: 10; -fx-font-size: 12; -fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-background-color: #f9f9f9; -fx-border-radius: 4; -fx-control-inner-background: #f9f9f9;" prefHeight="100" wrapText="true"/>
                        </VBox>

                        <!-- Date and Time Selection -->
                        <VBox spacing="12">
                            <Label text="Auction Schedule" styleClass="form-section-title"/>
                            <HBox spacing="20">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label text="Start Date" styleClass="form-label-register"/>
                                    <DatePicker fx:id="startDatePicker" style="-fx-padding: 8; -fx-font-size: 12; -fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-background-color: #f9f9f9; -fx-border-radius: 4;"/>
                                </VBox>
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label text="Start Time" styleClass="form-label-register"/>
                                    <HBox spacing="5">
                                        <Spinner fx:id="startHourSpinner" prefWidth="100" editable="true" style="-fx-padding: 8; -fx-font-size: 12; -fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-background-color: #f9f9f9; -fx-border-radius: 4;"/>
                                        <Label text=":" style="-fx-font-size: 14; -fx-text-fill: #2c2c2c;"/>
                                        <Spinner fx:id="startMinuteSpinner" prefWidth="100" editable="true" style="-fx-padding: 8; -fx-font-size: 12; -fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-background-color: #f9f9f9; -fx-border-radius: 4;"/>
                                    </HBox>
                                </VBox>
                            </HBox>
                            <HBox spacing="20">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label text="End Date" styleClass="form-label-register"/>
                                    <DatePicker fx:id="endDatePicker" style="-fx-padding: 8; -fx-font-size: 12; -fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-background-color: #f9f9f9; -fx-border-radius: 4;"/>
                                </VBox>
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label text="End Time" styleClass="form-label-register"/>
                                    <HBox spacing="5">
                                        <Spinner fx:id="endHourSpinner" prefWidth="100" editable="true" style="-fx-padding: 8; -fx-font-size: 12; -fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-background-color: #f9f9f9; -fx-border-radius: 4;"/>
                                        <Label text=":" style="-fx-font-size: 14; -fx-text-fill: #2c2c2c;"/>
                                        <Spinner fx:id="endMinuteSpinner" prefWidth="100" editable="true" style="-fx-padding: 8; -fx-font-size: 12; -fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-background-color: #f9f9f9; -fx-border-radius: 4;"/>
                                    </HBox>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Submit Button -->
                        <Button text="CREATE AUCTION" onAction="#handleCreateAuction" styleClass="dashboard-btn-primary" prefWidth="Infinity" prefHeight="45" style="-fx-font-size: 14;"/>
                    </VBox>
                </VBox>

                <!-- YOUR AUCTIONS SECTION -->
                <VBox spacing="12" style="-fx-border-color: #e8e6e1; -fx-border-width: 1; -fx-padding: 20; -fx-border-radius: 4; -fx-background-color: #ffffff;">
                    <VBox spacing="6">
                        <Label text="Your Active Auctions" styleClass="dashboard-section-title"/>
                        <Label text="Manage your ongoing auctions" styleClass="dashboard-section-subtitle"/>
                    </VBox>
                    <ListView fx:id="auctionList" style="-fx-padding: 10; -fx-border-radius: 4; -fx-border-color: #d0ccc6; -fx-background-color: #f9f9f9;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>