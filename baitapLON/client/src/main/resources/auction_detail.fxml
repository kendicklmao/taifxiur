<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="client.AuctionDetailController" spacing="10">
<Label fx:id="itemName"/>
<Label fx:id="currentPrice"/>
<TextField fx:id="bidAmount" promptText="Enter bid"/>
<Button text="Bid" onAction="#placeBid"/>
</VBox>
